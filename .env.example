# ============ 环境配置 ============
ENVIRONMENT=development  # production, development, test

# ============ API配置 ============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ============ 安全配置 ============
# 生产环境请使用强随机密钥: openssl rand -hex 32
SECRET_KEY=

# ============ JWT配置 ============
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ Cookie配置 ============
COOKIE_SECURE=false  # 生产环境设置为 true
COOKIE_DOMAIN=       # 可选，如 .example.com

# ============ TOTP配置 ============
TOTP_ISSUER=Drexor
TOTP_ENCRYPTION_SALT=

# ============ Redis配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_USE_SSL=false
REDIS_TIMEOUT=10

# ============ 数据库配置 (PostgreSQL) ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=drexor
DB_ECHO=false

# ============ 日志配置 ============
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ============ 跨域配置 ============
# 多个域名用逗号分隔
CORS_ORIGINS=["*"]
